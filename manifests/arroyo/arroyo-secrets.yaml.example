---
# Arroyo secrets for database and S3/MinIO access
# Copy to arroyo-secrets.yaml and fill in credentials
apiVersion: v1
kind: Secret
metadata:
  name: arroyo-secrets
  namespace: data-arroyo
  labels:
    app: arroyo
type: Opaque
stringData:
  # PostgreSQL credentials (same as other services)
  POSTGRES_PASSWORD: "YOUR_POSTGRES_PASSWORD"

  # MinIO credentials (matches minio-secret in data-storage)
  S3_ACCESS_KEY_ID: "YOUR_ACCESS_KEY"
  S3_SECRET_ACCESS_KEY: "YOUR_SECRET_KEY"

  # Optional: API authentication token
  # ARROYO_API_TOKEN: "changeme"
