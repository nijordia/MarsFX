# Trino secret values - copy to values.secret.yaml and fill in credentials
# This file contains S3/MinIO credentials for the Iceberg catalog

additionalCatalogs:
  iceberg: |
    connector.name=iceberg
    iceberg.catalog.type=rest
    iceberg.rest-catalog.uri=http://lakekeeper-chart.data-lakekeeper.svc.cluster.local:8181/catalog
    iceberg.rest-catalog.warehouse=marsfx
    fs.native-s3.enabled=true
    s3.endpoint=http://minio.data-storage.svc.cluster.local:9000
    s3.path-style-access=true
    s3.region=us-east-1
    s3.aws-access-key=YOUR_ACCESS_KEY
    s3.aws-secret-key=YOUR_SECRET_KEY
